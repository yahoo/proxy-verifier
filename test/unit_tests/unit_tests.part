Import("*")
PartName("tests")

DependsOn([
    Component("libswoc.static"),
    Component("openssl", requires=REQ.DEFAULT(internal=False)),
    Component("nghttp2", requires=REQ.DEFAULT(internal=False)),
    Component("ngtcp2", requires=REQ.DEFAULT(internal=False)),
    Component("nghttp3", requires=REQ.DEFAULT(internal=False)),
    Component("yaml-cpp"),
    "proxy-verifier.core",
])

env.AppendUnique(CCFLAGS=['-std=c++17', '-g'], )

files = [
    "test_YamlParser.cc",
    "test_chunk_parsing.cc",
    "test_http.cc",
    "test_https.cc",
    "test_verification.cc",
    "unit_test_main.cc",
]
env.UnitTest(
    "tests",
    files,
    # data file we need for the test to pass
    data_src=[Pattern(src_dir="#", includes=['doc/conf.py'])])
